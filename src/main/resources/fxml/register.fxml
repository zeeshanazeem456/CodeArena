<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="720.0" prefWidth="1100.0" spacing="12.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.codearena.controller.RegisterController">
    <padding>
        <Insets top="32.0" right="32.0" bottom="32.0" left="32.0" />
    </padding>

    <Label style="-fx-font-size: 30px; -fx-font-weight: bold;" text="Create Account" />
    <TextField fx:id="usernameField" maxWidth="320.0" promptText="Username" />
    <TextField fx:id="emailField" maxWidth="320.0" promptText="Email" />
    <PasswordField fx:id="passwordField" maxWidth="320.0" promptText="Password" />
    <PasswordField fx:id="confirmPasswordField" maxWidth="320.0" promptText="Confirm Password" />
    <Button mnemonicParsing="false" onAction="#handleRegister" text="Register" />
    <Label fx:id="errorLabel" managed="false" style="-fx-text-fill: #C62828;" text="" visible="false" />
    <Hyperlink mnemonicParsing="false" onAction="#goToLogin" text="Back to Login" />
</VBox>
