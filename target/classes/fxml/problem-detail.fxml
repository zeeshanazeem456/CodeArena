<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="720.0" prefWidth="1100.0" spacing="14.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.codearena.controller.ProblemDetailController">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12.0">
        <Label fx:id="titleLabel" style="-fx-font-size: 28px; -fx-font-weight: bold;" text="Problem Title" />
        <Label fx:id="difficultyLabel" text="Difficulty" />
    </HBox>

    <Label fx:id="categoryLabel" text="Category: -" />
    <Label fx:id="tagsLabel" text="Tags: -" />

    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Description" />
    <ScrollPane fx:id="descriptionArea" fitToWidth="true" prefHeight="240.0" />

    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Sample Test Cases" />
    <VBox fx:id="sampleTestCasesBox" spacing="10.0" />

    <HBox spacing="12.0">
        <Button mnemonicParsing="false" onAction="#goToEditor" text="Start Coding" />
        <Button mnemonicParsing="false" onAction="#goToProblemList" text="Back" />
    </HBox>
</VBox>
