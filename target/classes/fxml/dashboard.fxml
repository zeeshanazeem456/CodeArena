<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="720.0" prefWidth="1100.0" spacing="14.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.codearena.controller.DashboardController">
    <padding>
        <Insets top="32.0" right="32.0" bottom="32.0" left="32.0" />
    </padding>

    <Label style="-fx-font-size: 30px; -fx-font-weight: bold;" text="Dashboard" />
    <Label text="Choose where to go next." />
    <HBox alignment="CENTER" spacing="12.0">
        <Button mnemonicParsing="false" onAction="#goToProblems" text="Problems" />
        <Button mnemonicParsing="false" onAction="#logout" text="Logout" />
    </HBox>
</VBox>
